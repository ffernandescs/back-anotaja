# Configurações do Servidor
NODE_ENV=development
PORT=3000

# Configurações do Banco deDados
DATABASE_URL=postgresql://user:password@localhost:5432/anotaja

# Configurações da Chave Privada (Menu Integrado Style)
# Formato: 64 caracteres hexadecimais (256 bits)
# Exemplo: 5db2E73cB24Dc42988f6E43E217B95f034a83Fa09DE057C98Fa6a100F4A896dB
# Gerar nova chave: GET /admin/sign/generate-key
PRIVATE_KEY=BE03637B09B8391582B8F9A18FECB5D49CB1F8FA30BEBBED0BFC9103C2338BB2

# Configurações do QZ Tray
QZ_TRAY_CERTIFICATE_PATH=./public/cert/digital-certificate.txt

# Configurações do Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
FRONTEND_URL=https://app.anotaja.com

# JWT
JWT_SECRET=your-jwt-secret-here
OWNER_JWT_SECRET=your-owner-jwt-secret-here
PARTNER_JWT_SECRET=your-partner-jwt-secret-here

# Outras configurações...
CORS_ORIGIN=http://localhost:3001

# Email para receber interesses em teste do sistema
MASTER_EMAIL=master@anotaja.shop

# WhatsApp do master para contato
MASTER_WHATSAPP=5511999999999
