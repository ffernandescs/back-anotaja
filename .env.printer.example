# ── Configurações da Impressora Térmica ────────────────────────────────
# Habilitar integração com impressora térmica
PRINTER_ENABLED=false

# Endpoint do servidor da impressora (emulador)
PRINTER_ENDPOINT=http://localhost:3131

# Marca da impressora (affects formatting)
PRINTER_BRAND=daruma

# Imprimir automaticamente quando pedido é criado
PRINTER_AUTO_PRINT=true

# Imprimir também quando pedido é pago (segunda via)
PRINTER_PRINT_ON_PAYMENT=false

# Número de cópias por cupom
PRINTER_COPIES=1
